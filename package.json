{
  "name": "webhook-fortress",
  "version": "0.1.0",
  "description": "Reliable webhook ingestion engine with idempotency and concurrency safety",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepack": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "webhooks",
    "idempotency",
    "events",
    "reliability"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nikotheabstract/webhook-fortress.git"
  },
  "bugs": {
    "url": "https://github.com/Nikotheabstract/webhook-fortress/issues"
  },
  "homepage": "https://github.com/Nikotheabstract/webhook-fortress#readme",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
